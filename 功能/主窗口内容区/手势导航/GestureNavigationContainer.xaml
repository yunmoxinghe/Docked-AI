<UserControl
    x:Class="GestureNavigation.GestureNavigationContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="GestureAcrylicTint">#C0FFFFFF</Color>
                    <StaticResource x:Key="GestureIndicatorStrokeColor" ResourceKey="SystemAccentColorLight1"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="GestureAcrylicTint">#C0000000</Color>
                    <StaticResource x:Key="GestureIndicatorStrokeColor" ResourceKey="SystemAccentColorLight1"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <Color x:Key="GestureAcrylicTint">#C0000000</Color>
                    <StaticResource x:Key="GestureIndicatorStrokeColor" ResourceKey="SystemAccentColorLight1"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        根容器：ManipulationMode="System" 允许 VisualInteractionSource 捕获触摸板输入
        将你的 Frame 放在 ContentPresenter 的位置，或直接替换为 Frame
    -->
    <Grid x:Name="RootContainer" ManipulationMode="System">

        <!-- 内容插槽 -->
        <ContentPresenter x:Name="InnerContent" Content="{x:Bind Content, Mode=OneWay}"/>

        <!-- 后退指示器 -->
        <Border
            x:Name="BackIcon_Border"
            Width="56"
            Height="56"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Margin="16,0,0,0"
            CornerRadius="28"
            BorderThickness="2"
            BorderBrush="{ThemeResource GestureIndicatorStrokeColor}"
            IsHitTestVisible="False"
            Canvas.ZIndex="1000">
            <Border.Background>
                <AcrylicBrush
                    TintColor="{ThemeResource GestureAcrylicTint}"
                    TintOpacity="0.5"
                    FallbackColor="#80000000"/>
            </Border.Background>
            <Border.BackgroundTransition>
                <BrushTransition Duration="0:0:0.3"/>
            </Border.BackgroundTransition>
            <TextBlock
                x:Name="BackIconText"
                Text="&#xE72B;"
                FontFamily="Segoe Fluent Icons"
                FontSize="24"
                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Border>

        <!-- 前进指示器 -->
        <Border
            x:Name="ForwardIcon_Border"
            Width="56"
            Height="56"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,16,0"
            CornerRadius="28"
            BorderThickness="2"
            BorderBrush="{ThemeResource GestureIndicatorStrokeColor}"
            IsHitTestVisible="False"
            Canvas.ZIndex="1000">
            <Border.Background>
                <AcrylicBrush
                    TintColor="{ThemeResource GestureAcrylicTint}"
                    TintOpacity="0.5"
                    FallbackColor="#80000000"/>
            </Border.Background>
            <Border.BackgroundTransition>
                <BrushTransition Duration="0:0:0.3"/>
            </Border.BackgroundTransition>
            <TextBlock
                x:Name="ForwardIconText"
                Text="&#xE72A;"
                FontFamily="Segoe Fluent Icons"
                FontSize="24"
                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
