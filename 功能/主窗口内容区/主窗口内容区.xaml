<UserControl
    x:Class="Docked_AI.Features.MainWindowContent.MainWindowContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="48" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="4,6,2,4">
            <Border
                x:Name="PageCard"
                CornerRadius="4"
                Padding="24,20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="38"
                        FontWeight="SemiBold" />
                    <TextBlock
                        Text="{Binding PageBody}"
                        TextWrapping="WrapWholeWords"
                        Opacity="0.88"
                        FontSize="16" />
                </StackPanel>
            </Border>
        </Grid>

        <controls:NavigationView
            x:Name="RightNavigationView"
            Grid.Column="2"
            Width="48"
            Margin="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            AlwaysShowHeader="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            IsPaneOpen="False"
            PaneDisplayMode="LeftCompact"
            OpenPaneLength="220"
            CompactPaneLength="48"
            SelectionChanged="RightNavigationView_SelectionChanged"
            FlowDirection="RightToLeft">
            <controls:NavigationView.MenuItems>
                <controls:NavigationViewItem
                    x:Name="HomeNavigationItem"
                    Content="&#x4E3B;&#x9875;"
                    Tag="0"
                    IsSelected="True">
                    <controls:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>

                <controls:NavigationViewItem
                    Content="&#x5DE5;&#x4F5C;&#x533A;"
                    Tag="1">
                    <controls:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
            </controls:NavigationView.MenuItems>
        </controls:NavigationView>
    </Grid>
</UserControl>
