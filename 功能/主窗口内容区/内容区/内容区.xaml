<UserControl
    x:Class="Docked_AI.Features.MainWindowContent.ContentArea.ContentArea"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:animations="using:Microsoft.UI.Xaml.Media.Animation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="ContentBorder"
        CornerRadius="4"
        Padding="0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
        <Grid x:Name="ContentGrid">
            <!-- 第一层：页面内容 Frame -->
            <controls:Frame
                x:Name="ContentFrame"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                SizeChanged="ContentFrame_SizeChanged">
                <controls:Frame.ContentTransitions>
                    <TransitionCollection>
                        <animations:NavigationThemeTransition>
                            <animations:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                                <animations:DrillInNavigationTransitionInfo />
                            </animations:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                        </animations:NavigationThemeTransition>
                    </TransitionCollection>
                </controls:Frame.ContentTransitions>
            </controls:Frame>

            <!-- 第二层：通用控件/装饰层 -->
            <Grid
                x:Name="OverlayLayer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False" />

            <!-- 第三层：顶部应用栏 -->
            <Grid
                x:Name="TopAppBarContainer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="48"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                IsHitTestVisible="True">

                <!-- 分隔线 -->
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Height="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                    Opacity="0.5" />

                <!-- 中间区域（可扩展） -->
                <ContentPresenter
                    x:Name="TopBarCenterContent"
                    Margin="48,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- 第四层：左右按钮层（始终在最顶层，不随顶部栏显隐） -->
            <Grid
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="48"
                IsHitTestVisible="True"
                Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧区域（可扩展） -->
                <StackPanel
                    x:Name="TopBarLeftPanel"
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4" />

                <!-- 右侧区域（可扩展） -->
                <StackPanel
                    x:Name="TopBarRightPanel"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
