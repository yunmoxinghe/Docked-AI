<UserControl
    x:Class="Docked_AI.Features.MainWindowContent.ContentArea.ContentArea"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:animations="using:Microsoft.UI.Xaml.Media.Animation"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="ContentBorder"
        CornerRadius="4"
        Padding="0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
        <Grid x:Name="ContentGrid">
            <!-- 第一层：页面内容 Frame -->
            <controls:Frame
                x:Name="ContentFrame"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                SizeChanged="ContentFrame_SizeChanged">
                <controls:Frame.ContentTransitions>
                    <TransitionCollection>
                        <animations:NavigationThemeTransition>
                            <animations:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                                <animations:DrillInNavigationTransitionInfo />
                            </animations:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                        </animations:NavigationThemeTransition>
                    </TransitionCollection>
                </controls:Frame.ContentTransitions>
            </controls:Frame>

            <!-- 第二层：通用控件/装饰层 -->
            <Grid
                x:Name="OverlayLayer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False" />

            <!-- 第三层：顶部应用栏 -->
            <Grid
                x:Name="TopAppBarContainer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="48"
                Visibility="Collapsed"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                IsHitTestVisible="True">

                <!-- 分隔线 -->
                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Height="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                    Opacity="0.5" />

                <!-- 中间区域（可扩展） -->
                <ContentPresenter
                    x:Name="TopBarCenterContent"
                    Margin="48,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- 第四层：左右按钮层（始终在最顶层，不随顶部栏显隐） -->
            <Grid
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="48"
                IsHitTestVisible="True"
                Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧区域 -->
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4">
                    
                    <!-- 返回按钮（可选） -->
                    <Button
                        x:Name="BackButton"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="返回"
                        CornerRadius="4"
                        PointerEntered="BackButton_PointerEntered"
                        PointerExited="BackButton_PointerExited"
                        Click="BackButton_Click">
                        <controls:AnimatedIcon x:Name="BackAnimatedIcon" Width="16" Height="16">
                            <controls:AnimatedIcon.Source>
                                <animatedvisuals:AnimatedBackVisualSource />
                            </controls:AnimatedIcon.Source>
                            <controls:AnimatedIcon.FallbackIconSource>
                                <SymbolIconSource Symbol="Back" />
                            </controls:AnimatedIcon.FallbackIconSource>
                        </controls:AnimatedIcon>
                    </Button>

                    <!-- 菜单按钮（可选） -->
                    <Button
                        x:Name="MenuButton"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="菜单"
                        CornerRadius="4"
                        PointerEntered="MenuButton_PointerEntered"
                        PointerExited="MenuButton_PointerExited"
                        Click="MenuButton_Click">
                        <controls:AnimatedIcon x:Name="MenuAnimatedIcon" Width="16" Height="16">
                            <controls:AnimatedIcon.Source>
                                <animatedvisuals:AnimatedGlobalNavigationButtonVisualSource />
                            </controls:AnimatedIcon.Source>
                            <controls:AnimatedIcon.FallbackIconSource>
                                <FontIconSource Glyph="&#xE700;" />
                            </controls:AnimatedIcon.FallbackIconSource>
                        </controls:AnimatedIcon>
                    </Button>

                    <!-- 自定义左侧内容区域 -->
                    <StackPanel
                        x:Name="TopBarLeftPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="4" />
                </StackPanel>

                <!-- 右侧区域 -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4">
                    
                    <!-- 自定义右侧内容区域 -->
                    <StackPanel
                        x:Name="TopBarRightPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="4" />

                    <!-- 更多按钮 -->
                    <Button
                        x:Name="MoreButton"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="更多"
                        CornerRadius="4">
                        <FontIcon Glyph="&#xE712;" />
                        <Button.Flyout>
                            <MenuFlyout x:Name="MoreMenuFlyout" Placement="BottomEdgeAlignedRight">
                                <!-- 菜单项将通过代码动态添加 -->
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
