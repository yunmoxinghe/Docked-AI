<Page
    x:Class="Docked_AI.Features.Pages.Home.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="WidthStates">
            <VisualState x:Name="NarrowState">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="SummaryGrid.ColumnSpacing" Value="8" />
                    <Setter Target="SummaryGridRow2.Height" Value="Auto" />
                    <Setter Target="SummaryGridColumn2.Width" Value="0" />
                    <Setter Target="StatusCard.(Grid.Column)" Value="0" />
                    <Setter Target="StatusCard.(Grid.Row)" Value="1" />
                </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="WideState">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="700" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="SummaryGrid.ColumnSpacing" Value="12" />
                    <Setter Target="SummaryGridRow2.Height" Value="0" />
                    <Setter Target="SummaryGridColumn2.Width" Value="*" />
                    <Setter Target="StatusCard.(Grid.Column)" Value="1" />
                    <Setter Target="StatusCard.(Grid.Row)" Value="0" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="主页" FontSize="32" FontWeight="SemiBold" />
            <TextBlock Text="欢迎使用 Docked AI，这里展示你的核心信息与快捷入口。" TextWrapping="WrapWholeWords" Opacity="0.9" />

            <Grid x:Name="SummaryGrid" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="SummaryGridColumn2" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="SummaryGridRow2" Height="0" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Padding="16" CornerRadius="8" Background="{ThemeResource LayerFillColorAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="今日任务" FontWeight="SemiBold" />
                        <TextBlock Text="3 项待处理" FontSize="24" />
                    </StackPanel>
                </Border>

                <Border x:Name="StatusCard" Grid.Column="1" Padding="16" CornerRadius="8" Background="{ThemeResource LayerFillColorAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="系统状态" FontWeight="SemiBold" />
                        <TextBlock Text="运行正常" FontSize="24" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

