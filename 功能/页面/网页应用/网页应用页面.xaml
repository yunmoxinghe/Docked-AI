<Page
    x:Class="Docked_AI.Features.Pages.WebApp.WebAppPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    UseLayoutRounding="True">
    <Grid
        Padding="24,16"
        Background="Transparent">
        <StackPanel
            MaxWidth="560"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Spacing="16">
            <Grid
                x:Name="SiteIconHost"
                Width="64"
                Height="64"
                HorizontalAlignment="Center">
                <Image
                    x:Name="SiteIconImage"
                    Width="64"
                    Height="64"
                    Stretch="UniformToFill"
                    Visibility="Collapsed" />
                <FontIcon
                    x:Name="SiteIconFallback"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Glyph="&#xE774;"
                    FontSize="56" />
            </Grid>

            <TextBox
                x:Name="AppNameTextBox"
                Header="名称"
                PlaceholderText="输入应用名称" />

            <TextBox
                x:Name="WebsiteUrlTextBox"
                Header="网址"
                PlaceholderText="https://example.com"
                InputScope="Url"
                TextChanged="WebsiteUrlTextBox_TextChanged" />

            <TextBlock
                x:Name="LookupStatusText"
                Opacity="0.7" />

            <Button
                HorizontalAlignment="Stretch"
                Content="确定" />
        </StackPanel>
    </Grid>
</Page>
