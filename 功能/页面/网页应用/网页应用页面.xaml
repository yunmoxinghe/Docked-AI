<Page
    x:Class="Docked_AI.Features.Pages.WebApp.WebAppPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    UseLayoutRounding="True">
    <Grid
        Padding="24,16"
        Background="Transparent">
        <StackPanel
            MaxWidth="560"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Spacing="12">
            <Button
                x:Name="ChooseIconButton"
                Width="72"
                Height="72"
                HorizontalAlignment="Center"
                Padding="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="ChooseIconButton_Click">
                <Grid
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Image
                        x:Name="SiteIconImage"
                        Width="64"
                        Height="64"
                        Stretch="UniformToFill"
                        Visibility="Collapsed" />
                    <FontIcon
                        x:Name="SiteIconFallback"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Glyph="&#xE774;"
                        FontSize="56" />
                </Grid>
            </Button>

            <Button
                x:Name="RestoreAutoIconButton"
                x:Uid="WebAppPage_RestoreAutoIcon"
                HorizontalAlignment="Center"
                Padding="10,4"
                FontSize="12"
                Content="恢复自动图标"
                Click="RestoreAutoIconButton_Click" />

            <TextBox
                x:Name="AppNameTextBox"
                x:Uid="WebAppPage_NameHeader"
                Header="名称"
                PlaceholderText="输入应用名称"
                TextChanged="AppNameTextBox_TextChanged" />

            <TextBox
                x:Name="WebsiteUrlTextBox"
                x:Uid="WebAppPage_UrlHeader"
                Header="网址"
                PlaceholderText="https://example.com"
                InputScope="Url"
                TextChanged="WebsiteUrlTextBox_TextChanged" />

            <TextBlock
                x:Name="LookupStatusText"
                Opacity="0.7" />

            <Button
                x:Name="ConfirmButton"
                x:Uid="WebAppPage_Confirm"
                HorizontalAlignment="Stretch"
                Content="确定"
                Click="ConfirmButton_Click" />
        </StackPanel>
    </Grid>
</Page>
