<Page
    x:Class="Docked_AI.Features.Pages.WebApp.Browser.WebBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="TopBarHost"
            Grid.Row="0"
            CornerRadius="4,4,0,0"
            Background="#01000000"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0"
            PointerPressed="TopBarHost_PointerPressed">
            <Grid x:Name="TopBarGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Viewbox Width="20" Height="20" VerticalAlignment="Center" IsHitTestVisible="False">
                    <Grid Width="20" Height="20">
                        <Image
                            x:Name="SiteIconImage"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="SiteIconFallback"
                            Glyph="&#xE774;"
                            FontSize="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                </Viewbox>
                <StackPanel
                    x:Name="TitleStackPanel"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
                    <TextBlock
                        x:Name="TitleText"
                        TextTrimming="CharacterEllipsis"
                        FontWeight="SemiBold"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="UrlText"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        ToolTipService.ToolTip="">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                                <Setter Property="FontSize" Value="{StaticResource CaptionTextBlockFontSize}" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <ProgressBar
                    x:Name="LoadingProgressBar"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Bottom"
                    IsIndeterminate="True"
                    Visibility="Collapsed"
                    Height="2"
                    Margin="0,0,0,-2"
                    IsHitTestVisible="False" />
            </Grid>
        </Border>

        <!-- 顶部栏下方的自适应色块 -->
        <Border
            x:Name="TopBarExtension"
            Grid.Row="1"
            Background="Transparent" />

        <!-- 中心区域背景 -->
        <Border
            x:Name="CenterAreaBackground"
            Grid.Row="2"
            Background="Transparent" />

        <!-- 底部栏上方的自适应色块 -->
        <Border
            x:Name="BottomBarExtension"
            Grid.Row="3"
            Background="Transparent" />

        <controls:WebView2
            x:Name="WebView"
            Grid.Row="1"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <!-- 圆角容器（实验特性） -->
        <Border
            x:Name="RoundedWebViewContainer"
            Grid.Row="1"
            Grid.RowSpan="3"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            Visibility="Collapsed">
            <controls:WebView2
                x:Name="RoundedWebView"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        </Border>

        <Border
            x:Name="BottomBarHost"
            Grid.Row="4"
            CornerRadius="0,0,4,4"
            Background="Transparent"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0">
            <Grid HorizontalAlignment="Center">
                <StackPanel 
                    x:Name="BottomButtonsPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <controls:AppBarButton
                        x:Name="BackButton"
                        Click="BackButton_Click"
                        LabelPosition="Collapsed">
                        <controls:AppBarButton.Icon>
                            <SymbolIcon Symbol="Back" x:Name="BackIcon" />
                        </controls:AppBarButton.Icon>
                    </controls:AppBarButton>
                    <controls:AppBarButton
                        x:Name="ForwardButton"
                        Click="ForwardButton_Click"
                        LabelPosition="Collapsed">
                        <controls:AppBarButton.Icon>
                            <SymbolIcon Symbol="Forward" x:Name="ForwardIcon" />
                        </controls:AppBarButton.Icon>
                    </controls:AppBarButton>
                    <controls:AppBarButton
                        x:Name="RefreshButton"
                        Click="RefreshButton_Click"
                        LabelPosition="Collapsed">
                        <controls:AppBarButton.Icon>
                            <SymbolIcon Symbol="Refresh" x:Name="RefreshIcon" />
                        </controls:AppBarButton.Icon>
                    </controls:AppBarButton>
                    <controls:AppBarButton
                        x:Name="CopyUrlButton"
                        Click="CopyUrlButton_Click"
                        LabelPosition="Collapsed">
                        <controls:AppBarButton.Icon>
                            <SymbolIcon Symbol="Copy" x:Name="CopyIcon" />
                        </controls:AppBarButton.Icon>
                    </controls:AppBarButton>
                    <controls:AppBarButton
                        x:Name="OpenExternalButton"
                        Click="OpenExternalButton_Click"
                        LabelPosition="Collapsed">
                        <controls:AppBarButton.Icon>
                            <SymbolIcon Symbol="World" x:Name="OpenExternalIcon" />
                        </controls:AppBarButton.Icon>
                    </controls:AppBarButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>