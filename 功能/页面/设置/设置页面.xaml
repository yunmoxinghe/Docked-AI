<Page
    x:Class="Docked_AI.Features.Pages.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:devwinui="using:DevWinUI"
    mc:Ignorable="d"
    UseLayoutRounding="True">
    <Grid
        x:Name="RootGrid"
        Padding="0"
        UseLayoutRounding="True">
        <ScrollViewer
            x:Name="SettingsScrollViewer"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            HorizontalContentAlignment="Stretch"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="PageContentPanel"
                Margin="16,0"
                UseLayoutRounding="True"
                Spacing="0">
                <Border Height="40" />
                <TextBlock
                    x:Uid="SettingsPage_Title"
                    FontSize="32"
                    FontWeight="SemiBold" />
                <Border Height="36" />

                <StackPanel
                    x:Name="CardsPanel"
                    Spacing="4">
                    <!-- 当状态为 DisabledByUser 时显示提示信息 -->
                    <InfoBar
                        x:Uid="SettingsPage_UserDisabledInfo"
                        Severity="Informational"
                        IsOpen="{x:Bind ViewModel.ShowUserDisabledInfo, Mode=OneWay}"
                        IsClosable="False"
                        Visibility="{x:Bind ViewModel.ShowUserDisabledInfo, Mode=OneWay}"/>

                    <!-- 当状态为 DisabledByPolicy 时显示警告 -->
                    <InfoBar
                        x:Uid="SettingsPage_PolicyWarning"
                        Severity="Warning"
                        IsOpen="{x:Bind ViewModel.ShowPolicyWarning, Mode=OneWay}"
                        IsClosable="False"
                        Visibility="{x:Bind ViewModel.ShowPolicyWarning, Mode=OneWay}"/>

                    <!-- 常规设置 -->
                    <controls:SettingsExpander Header="常规" IsExpanded="True">
                        <controls:SettingsExpander.Items>
                            <!-- 开机自启动设置 -->
                            <controls:SettingsCard 
                                x:Uid="SettingsPage_StartupHeader"
                                IsClickEnabled="True"
                                Click="OnSettingCardClick">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE7B5;" />
                                </controls:SettingsCard.HeaderIcon>
                                <controls:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="&#xE8A7;"/>
                                </controls:SettingsCard.ActionIcon>
                                <ToggleSwitch 
                                    IsOn="{x:Bind ViewModel.IsStartupEnabled, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.CanToggle, Mode=OneWay}"
                                    Toggled="OnToggleSwitched"/>
                            </controls:SettingsCard>

                            <controls:SettingsCard x:Uid="SettingsPage_LanguageHeader"
                                              IsClickEnabled="True"
                                              Click="OnLanguageCardClick"
                                              IsActionIconVisible="False">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xF2B7;"/>
                                </controls:SettingsCard.HeaderIcon>
                                <ComboBox x:Name="LanguageComboBox" 
                                          MinWidth="200"
                                          SelectionChanged="OnLanguageChanged">
                                    <ComboBoxItem Tag="zh-CN" x:Uid="Language_SimplifiedChinese"/>
                                    <ComboBoxItem Tag="zh-TW" x:Uid="Language_TraditionalChinese"/>
                                    <ComboBoxItem Tag="en-US" x:Uid="Language_English"/>
                                    <ComboBoxItem Tag="ja-JP" x:Uid="Language_Japanese"/>
                                    <ComboBoxItem Tag="ko-KR" x:Uid="Language_Korean"/>
                                    <ComboBoxItem Tag="fr-FR" x:Uid="Language_French"/>
                                    <ComboBoxItem Tag="de-DE" x:Uid="Language_German"/>
                                    <ComboBoxItem Tag="es-ES" x:Uid="Language_Spanish"/>
                                </ComboBox>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- 交互设置 -->
                    <controls:SettingsExpander Header="交互" IsExpanded="True">
                        <controls:SettingsExpander.Items>
                            <!-- 全局快捷键设置 -->
                            <controls:SettingsExpander x:Name="HotkeyExpander"
                                                  x:Uid="SettingsPage_HotkeyHeader"
                                                  IsExpanded="False">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE765;"/>
                                </controls:SettingsExpander.HeaderIcon>
                                
                                <ToggleSwitch 
                                    x:Name="HotkeyToggle"
                                    Toggled="OnHotkeyToggled"/>
                                
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Uid="SettingsPage_HotkeyConfigHeader"
                                                      IsClickEnabled="True"
                                                      Click="OnHotkeyButtonClick">
                                        <ItemsControl x:Name="HotkeyKeysDisplay" 
                                                    HorizontalAlignment="Right">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <devwinui:KeyVisual Content="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </controls:SettingsCard>
                                    
                                    <controls:SettingsCard x:Uid="SettingsPage_TouchpadSettingsHeader"
                                                      IsClickEnabled="True"
                                                      Click="OnTouchpadSettingsClick">
                                        <controls:SettingsCard.ActionIcon>
                                            <FontIcon Glyph="&#xE8A7;"/>
                                        </controls:SettingsCard.ActionIcon>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- 高级设置 -->
                    <controls:SettingsExpander Header="高级" IsExpanded="True">
                        <controls:SettingsExpander.Items>
                            <!-- 实验特性 -->
                            <controls:SettingsExpander 
                                Header="实验特性"
                                Description="启用实验性功能（可能不稳定）"
                                IsExpanded="False">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xF196;" />
                                </controls:SettingsExpander.HeaderIcon>
                                
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard 
                                        Header="WebView2 圆角"
                                        Description="为网页浏览器启用圆角效果，圆角大小自动同步上层容器">
                                        <ToggleSwitch 
                                            x:Name="RoundedWebViewToggle"
                                            Toggled="OnRoundedWebViewToggled"/>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- 关于 -->
                    <controls:SettingsExpander Header="关于" IsExpanded="True">
                        <controls:SettingsExpander.Items>
                            <controls:SettingsExpander x:Name="AboutAppExpander"
                                                  x:Uid="SettingsPage_AboutHeader"
                                                  IsExpanded="False">
                                <controls:SettingsExpander.HeaderIcon>
                                    <BitmapIcon UriSource="ms-appx:///Assets/Sparkles.ico" ShowAsMonochrome="False"/>
                                </controls:SettingsExpander.HeaderIcon>
                                
                                <TextBlock x:Name="VersionText" 
                                       x:Uid="SettingsPage_Version"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Uid="SettingsPage_LinksHeader"
                                                      HorizontalContentAlignment="Left"
                                                      ContentAlignment="Left">
                                        <StackPanel Margin="-12,0,0,0" Orientation="Vertical" Spacing="4">
                                            <HyperlinkButton Click="OnOpenGitHubClick">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8" />
                                                    <TextBlock Text="{x:Bind GetGitHubLinkText()}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                            <HyperlinkButton Click="OnSendFeedbackClick">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xED15;" FontSize="16"/>
                                                    <TextBlock Text="{x:Bind GetFeedbackLinkText()}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </HyperlinkButton>
                                            <HyperlinkButton x:Uid="SettingsPage_LicenseLink" Click="OnViewLicenseClick"/>
                                        </StackPanel>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>

                <Border Height="40" />
            </StackPanel>
        </ScrollViewer>

        <!-- 快捷键选择对话框 -->
        <ContentDialog
            x:Name="HotkeyDialog"
            Title="设置快捷键"
            PrimaryButtonText="确认"
            CloseButtonText="取消"
            DefaultButton="Primary"
            PrimaryButtonClick="OnHotkeyDialogPrimaryClick"
            CloseButtonClick="OnHotkeyDialogCloseClick">
            <StackPanel Spacing="16">
                <TextBlock Text="请按下您想要设置的快捷键组合" TextWrapping="Wrap"/>
                
                <ToggleButton
                    x:Name="HotkeyToggleButton"
                    MinHeight="80"
                    Padding="16"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Checked="HotkeyToggleButton_Checked"
                    Unchecked="HotkeyToggleButton_Unchecked"
                    PreviewKeyDown="HotkeyToggleButton_PreviewKeyDown"
                    PreviewKeyUp="HotkeyToggleButton_PreviewKeyUp">
                    <TextBlock
                        x:Name="HotkeyDisplayText"
                        Text="点击开始录制"
                        FontSize="16"
                        TextAlignment="Center"
                        TextWrapping="Wrap"/>
                </ToggleButton>

                <TextBlock
                    Text="提示：至少需要一个修饰键（Ctrl、Alt、Shift 或 Win）"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"/>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
