<Page
    x:Class="Docked_AI.Features.Pages.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    UseLayoutRounding="True">
    <Grid
        x:Name="RootGrid"
        Padding="0"
        UseLayoutRounding="True">
        <ScrollViewer
            x:Name="SettingsScrollViewer"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            HorizontalContentAlignment="Stretch"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="PageContentPanel"
                Margin="16,0"
                UseLayoutRounding="True"
                Spacing="0">
                <Border Height="40" />
                <TextBlock
                    x:Uid="SettingsPage_Title"
                    FontSize="32"
                    FontWeight="SemiBold" />
                <Border Height="36" />

                <StackPanel
                    x:Name="CardsPanel"
                    Spacing="4">
                    <controls:SettingsCard x:Uid="SettingsPage_LanguageHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xF2B7;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="LanguageComboBox" 
                                  MinWidth="200"
                                  SelectionChanged="OnLanguageChanged">
                            <ComboBoxItem Tag="zh-CN" Content="简体中文"/>
                            <ComboBoxItem Tag="zh-TW" Content="繁體中文"/>
                            <ComboBoxItem Tag="en-US" Content="English"/>
                            <ComboBoxItem Tag="ja-JP" Content="日本語"/>
                            <ComboBoxItem Tag="ko-KR" Content="한국어"/>
                            <ComboBoxItem Tag="fr-FR" Content="Français"/>
                            <ComboBoxItem Tag="de-DE" Content="Deutsch"/>
                            <ComboBoxItem Tag="es-ES" Content="Español"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    
                    <controls:SettingsExpander x:Name="AboutAppExpander"
                                          x:Uid="SettingsPage_AboutHeader"
                                          IsExpanded="False">
                        <controls:SettingsExpander.HeaderIcon>
                            <BitmapIcon UriSource="ms-appx:///Assets/Sparkles.ico" ShowAsMonochrome="False"/>
                        </controls:SettingsExpander.HeaderIcon>
                        
                        <TextBlock x:Name="VersionText" 
                               x:Uid="SettingsPage_Version"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard x:Uid="SettingsPage_AppDetailsHeader"
                                              HorizontalContentAlignment="Left"
                                              ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical" Spacing="4">
                                    <TextBlock x:Uid="SettingsPage_AppDetail1" FontSize="14"/>
                                    <TextBlock x:Uid="SettingsPage_AppDetail2" FontSize="14"/>
                                    <TextBlock x:Uid="SettingsPage_AppDetail3" FontSize="14"/>
                                    <TextBlock x:Uid="SettingsPage_AppDetail4" FontSize="14"/>
                                </StackPanel>
                            </controls:SettingsCard>
                            
                            <controls:SettingsCard x:Uid="SettingsPage_LinksHeader"
                                              HorizontalContentAlignment="Left"
                                              ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical" Spacing="4">
                                    <HyperlinkButton x:Uid="SettingsPage_GitHubLink" Click="OnOpenGitHubClick"/>
                                    <HyperlinkButton x:Uid="SettingsPage_FeedbackLink" Click="OnSendFeedbackClick"/>
                                    <HyperlinkButton x:Uid="SettingsPage_LicenseLink" Click="OnViewLicenseClick"/>
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>

                <Border Height="40" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
