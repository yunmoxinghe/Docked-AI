<Page
    x:Class="Docked_AI.Features.Pages.Lab.LabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    UseLayoutRounding="True">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid x:Name="RootGrid" Padding="0" UseLayoutRounding="True">
        <ScrollViewer
            x:Name="PageScrollViewer"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            HorizontalContentAlignment="Stretch"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="PageContentPanel"
                Margin="0"
                UseLayoutRounding="True"
                Spacing="0">

                <Border Height="40" />

                <TextBlock
                    x:Name="PageTitleBlock"
                    x:Uid="LabPage_Title"
                    FontSize="32"
                    FontWeight="SemiBold"/>

                <Border Height="8" />

                <TextBlock
                    x:Uid="LabPage_Subtitle"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Margin="0,0,0,0"/>

                <Border Height="28" />

                <StackPanel Spacing="4">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition FromVerticalOffset="50" />
                        <RepositionThemeTransition IsStaggeringEnabled="True" />
                    </StackPanel.ChildrenTransitions>

                    <!-- 实验特性分组 -->
                    <TextBlock
                        x:Uid="LabPage_ExperimentalSection"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Margin="1,0,0,4"/>

                    <!-- AI 实验室 -->
                    <controls:SettingsCard x:Uid="LabPage_AILabHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xF4A5;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="AILabToggle"
                            Toggled="OnAILabToggled"/>
                    </controls:SettingsCard>

                    <!-- WebView2 圆角 -->
                    <controls:SettingsCard x:Uid="LabPage_RoundedWebViewHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7C8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="RoundedWebViewToggle"
                            Toggled="OnRoundedWebViewToggled"/>
                    </controls:SettingsCard>

                    <!-- WinUI 右键菜单 -->
                    <controls:SettingsCard x:Uid="LabPage_WinUIContextMenuHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8C1;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="WinUIContextMenuToggle"
                            Toggled="OnWinUIContextMenuToggled"/>
                    </controls:SettingsCard>

                </StackPanel>

                <Border Height="28" />

                <!-- 顶部应用栏测试分组 -->
                <TextBlock
                    x:Uid="LabPage_TopAppBarSection"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Margin="1,0,0,4"/>

                <StackPanel Spacing="4">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition FromVerticalOffset="50" />
                        <RepositionThemeTransition IsStaggeringEnabled="True" />
                    </StackPanel.ChildrenTransitions>

                    <!-- 显示/隐藏顶部应用栏 -->
                    <controls:SettingsCard x:Uid="LabPage_TopBarVisibilityHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7C1;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="TopBarVisibilityToggle" />
                    </controls:SettingsCard>

                    <!-- 顶栏返回按钮 -->
                    <controls:SettingsCard x:Uid="LabPage_TopBarBackButtonHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE72B;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="TopBarBackButtonToggle"
                            Toggled="OnTopBarBackButtonToggled"/>
                    </controls:SettingsCard>

                    <!-- 顶栏菜单按钮 -->
                    <controls:SettingsCard x:Uid="LabPage_TopBarMenuButtonHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE700;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="TopBarMenuButtonToggle"
                            Toggled="OnTopBarMenuButtonToggled"/>
                    </controls:SettingsCard>

                    <!-- 设置中间标题 -->
                    <controls:SettingsCard x:Uid="LabPage_TopBarCenterHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8D2;" />
                        </controls:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBox
                                x:Name="CenterTitleInput"
                                PlaceholderText="输入标题文本"
                                Width="140"
                                VerticalAlignment="Center"/>
                            <Button
                                x:Uid="LabPage_TopBarCenterSetButton"
                                Click="OnSetCenterTitleClick"
                                VerticalAlignment="Center"/>
                            <Button
                                x:Uid="LabPage_TopBarCenterClearButton"
                                Click="OnClearCenterClick"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </controls:SettingsCard>

                    <!-- 设置右侧按钮 -->
                    <controls:SettingsCard x:Uid="LabPage_TopBarRightHeader">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE700;" />
                        </controls:SettingsCard.HeaderIcon>
                        <StackPanel Spacing="8" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Uid="LabPage_TopBarRightSetButton"
                                    Click="OnSetRightButtonClick"
                                    VerticalAlignment="Center"/>
                                <Button
                                    x:Uid="LabPage_TopBarRightClearButton"
                                    Click="OnClearRightButtonClick"
                                    VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock
                                x:Name="RightButtonStatus"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"
                                TextWrapping="Wrap"/>
                        </StackPanel>
                    </controls:SettingsCard>

                </StackPanel>

                <Border Height="40" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
