<Page
    x:Class="Docked_AI.Features.Pages.Test.WebView2RoundedCornerTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="0" Spacing="20">
            
            <!-- 标题 -->
            <TextBlock 
                Text="WebView2 圆角测试" 
                Style="{StaticResource TitleTextBlockStyle}"
                Margin="20,20,20,0"/>

            <!-- 测试1: 使用 Border 包住 WebView2 -->
            <StackPanel Spacing="10">
                <TextBlock 
                    Text="测试 1: 使用 Border 包住 WebView2 (8px 圆角)" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="20,0"/>
                
                <Border
                    Height="400"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Margin="0">
                    <controls:WebView2 
                        x:Name="WebViewInBorder"
                        Source="https://www.bing.com"/>
                </Border>
                
                <TextBlock 
                    Text="说明: Border 的 CornerRadius=&quot;8&quot; 自动实现圆角裁剪效果"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="20,0"/>
            </StackPanel>

            <!-- 测试2: 使用 Grid 包住 WebView2 -->
            <StackPanel Spacing="10">
                <TextBlock 
                    Text="测试 2: 使用 Grid 包住 WebView2 (8px 圆角)" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="20,0"/>
                
                <Grid
                    Height="400"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Margin="0">
                    <Border 
                        CornerRadius="8">
                        <controls:WebView2 
                            x:Name="WebViewInGrid"
                            Source="https://www.microsoft.com"/>
                    </Border>
                </Grid>
                
                <TextBlock 
                    Text="说明: Grid 设置 CornerRadius，内部使用 Border 裁剪 WebView2"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="20,0"/>
            </StackPanel>

            <!-- 测试3: 纯 Border 方案（推荐） -->
            <StackPanel Spacing="10">
                <TextBlock 
                    Text="测试 3: 纯 Border 方案 - 推荐 (8px 圆角)" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="20,0"/>
                
                <Border
                    Height="400"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource AccentControlElevationBorderBrush}"
                    BorderThickness="2"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    Margin="0">
                    <Border 
                        CornerRadius="7"
                        Margin="1">
                        <controls:WebView2 
                            x:Name="WebViewRecommended"
                            Source="https://github.com"/>
                    </Border>
                </Border>
                
                <TextBlock 
                    Text="说明: 外层 Border 提供边框和背景，内层 Border 负责裁剪圆角（半径略小以适配边框）"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="20,0"/>
            </StackPanel>

            <!-- 测试4: 无边框圆角方案 -->
            <StackPanel Spacing="10">
                <TextBlock 
                    Text="测试 4: 无边框圆角方案 (8px 圆角)" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="20,0"/>
                
                <Border
                    Height="400"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Margin="0">
                    <controls:WebView2 
                        x:Name="WebViewNoBorder"
                        Source="https://www.wikipedia.org"/>
                </Border>
                
                <TextBlock 
                    Text="说明: 单层 Border 无边框，仅使用 CornerRadius 实现圆角裁剪"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="20,0"/>
            </StackPanel>

            <!-- 测试5: 完全无背景无边框 -->
            <StackPanel Spacing="10">
                <TextBlock 
                    Text="测试 5: 完全透明背景 (12px 圆角)" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="20,0"/>
                
                <Border
                    Height="400"
                    CornerRadius="12"
                    Background="Transparent"
                    Margin="0">
                    <controls:WebView2 
                        x:Name="WebViewTransparent"
                        Source="https://www.bing.com"/>
                </Border>
                
                <TextBlock 
                    Text="说明: 完全透明背景，更大的圆角半径 (12px)"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="20,0"/>
            </StackPanel>

            <!-- 控制按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="20,0,20,20">
                <Button 
                    Content="刷新所有 WebView" 
                    Click="RefreshAll_Click"/>
                <Button 
                    Content="导航到测试页" 
                    Click="NavigateToTest_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
